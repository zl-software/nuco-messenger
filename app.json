{
  "expo": {
    "name": "Nuco",
    "slug": "nuco-messenger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nucomessenger",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0B0E",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.zlsoftware.nuco",
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": true
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock Nuco with Face ID.",
        "NSCameraUsageDescription": "Nuco uses the camera only to scan a contact's code.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.zlsoftware.nuco",
      "adaptiveIcon": {
        "backgroundColor": "#0A0B0E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS",
        "USE_BIOMETRIC",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_DATA_SYNC"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0B0E",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Nuco uses the camera only to scan a contact's code.",
          "recordAudioAndroid": false
        }
      ],
      "expo-notifications",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Unlock Nuco with Face ID."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e0f052f8-5a53-4efa-8e84-886af828a885"
      }
    }
  }
}
